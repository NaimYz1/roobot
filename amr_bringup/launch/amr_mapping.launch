<!-- ============================================================
     ONE-TIME MAPPING of the real room with the Livox Mid-360.

     Builds a 2D occupancy map from the SAME flattened Livox scan that AMCL
     will later localise against, so the map and the localisation scan are
     geometrically consistent (the fix for "white scan doesn't match black
     walls"). Run this ALONGSIDE robot_up.sh (which provides /livox/lidar +
     odom). Drive the robot slowly around the whole room, watch the map build
     in RViz (Fixed Frame = map), then save it.

     Prereq (once, on the robot):
       sudo apt install ros-melodic-gmapping ros-melodic-teleop-twist-keyboard

     Usage (ON THE ROBOT):
       roslaunch amr_bringup amr_mapping.launch
       # in another terminal, drive it around slowly:
       rosrun teleop_twist_keyboard teleop_twist_keyboard.py    # or use the joystick
       # when the map looks complete, SAVE it:
       rosrun map_server map_saver -f ~/amr_source/amr_bringup/maps/myroom
       # then commit + push the new myroom.pgm/.yaml and launch nav with:
       #   roslaunch amr_bringup amr_jackal_real.launch \
       #       map_file:=$(rospack find amr_bringup)/maps/myroom.yaml
============================================================ -->
<launch>
  <!-- mount geometry: identical to amr_jackal_real.launch so the mapping scan
       and the later localisation scan are produced the SAME way -->
  <arg name="livox_topic"     default="/livox/lidar"/>
  <arg name="lidar_height"    default="0.447"/>
  <arg name="lidar_x"         default="0.0"/>
  <arg name="mount_pitch_rad" default="0.666988"/>
  <arg name="z_min"           default="0.15"/>
  <arg name="z_max"           default="1.50"/>

  <!-- base_link -> livox_frame (same tilt as the real launch) -->
  <node pkg="tf" type="static_transform_publisher" name="livox_tf"
        args="$(arg lidar_x) 0 $(arg lidar_height) 0 $(arg mount_pitch_rad) 0 base_link livox_frame 50"/>

  <!-- Livox 3D cloud -> 2D /scan (SAME flatten AMCL will use later) -->
  <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node"
        name="livox_to_scan" output="screen">
    <remap from="cloud_in" to="$(arg livox_topic)"/>
    <remap from="scan"     to="/scan"/>
    <rosparam subst_value="true">
      target_frame: base_link
      transform_tolerance: 0.05
      min_height: $(arg z_min)
      max_height: $(arg z_max)
      angle_min: -3.1415926
      angle_max: 3.1415926
      angle_increment: 0.0058
      scan_time: 0.1
      range_min: 0.4
      range_max: 30.0
      use_inf: true
      concurrency_level: 1
    </rosparam>
  </node>

  <!-- gmapping SLAM: builds map from /scan using odom->base_link -->
  <node pkg="gmapping" type="slam_gmapping" name="gmapping" output="screen">
    <remap from="scan" to="/scan"/>
    <param name="base_frame"          value="base_link"/>
    <param name="odom_frame"          value="odom"/>
    <param name="map_frame"           value="map"/>
    <param name="map_update_interval" value="2.0"/>
    <param name="maxUrange"           value="15.0"/>
    <param name="maxRange"            value="20.0"/>
    <param name="delta"               value="0.05"/>   <!-- 5 cm, matches planner -->
    <param name="linearUpdate"        value="0.2"/>
    <param name="angularUpdate"       value="0.2"/>
    <param name="temporalUpdate"      value="0.5"/>
    <param name="particles"           value="50"/>
    <param name="xmin"                value="-25.0"/>
    <param name="ymin"                value="-25.0"/>
    <param name="xmax"                value="25.0"/>
    <param name="ymax"                value="25.0"/>
    <param name="minimumScore"        value="50"/>
  </node>
</launch>
